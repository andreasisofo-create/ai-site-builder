# ============================================================
# Rally di Roma Capitale — Chatbot Configuration
# Copia questo file in .env e compila i valori reali
# MAI committare .env su git
# ============================================================

# --- OpenRouter AI (LLM + Vision) ---
# Chiave API da https://openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-...
# Modello da usare (default: anthropic/claude-3.5-sonnet)
AI_MODEL=anthropic/claude-3.5-sonnet

# --- Groq Whisper (Trascrizione note vocali) ---
# Registrati su https://console.groq.com — piano gratuito: 25.000 min/mese
# Senza questa chiave le note vocali non funzionano (bot risponde con messaggio cortese)
GROQ_API_KEY=gsk_...

# --- Telegram Bot (Fase 1) ---
# Token ottenuto da BotFather: /newbot
TELEGRAM_BOT_TOKEN=7123456789:AAH...

# Secret casuale per verificare che gli update arrivino da Telegram
# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TELEGRAM_WEBHOOK_SECRET=cambia_con_stringa_casuale_lunga

# --- Server ---
PORT=3000

# --- CORS ---
# URL separati da virgola che possono chiamare l'API
# Includere sempre il sito WordPress dell'evento
CORS_ORIGINS=https://www.rallydiromacapitale.it,https://rallydiromacapitale.it

# --- Sessioni AI ---
# Durata sessione in minuti prima che venga eliminata per inattività
SESSION_TTL_MINUTES=30

# --- Rate Limiting ---
# Richieste massime per IP al minuto per /api/chat (widget web)
RATE_LIMIT_CHAT_PER_MINUTE=30

# Richieste massime per IP al minuto per /api/telegram
# Alto perché i messaggi arrivano tutti dai server Telegram
RATE_LIMIT_TELEGRAM_PER_MINUTE=200
